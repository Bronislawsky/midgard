#!/usr/bin/env bash
# file : ./scripts/restic-sync
#------------------------------------------------------------------------------
#
#         .__    .___                      .___
#   _____ |__| __| _/ _________ _______  __| _/
#  /     \|  |/ __ | / ___\__  \\_  __ \/ __ |
# |  Y Y  \  / /_/ | /_/  > __ \|  | \/ /_/ |
# |__|_|  /__\____ |\___  (____  /__|  \____ |
#       \/        \/_____/     \/           \/
#
# restic-sync — back up LOCAL_SYNC_PATH to S3 with retention
#   - requires MIDGARD_MAIN=1 + global config loaded (RESTIC_BIN, retries)
#   - expects CONFIG_SITES map already populated
#   - writes RESTIC=OK|FAIL|SKIPPED into MIDGARD_SESSION_REPORT_DIR/<site>.report
#------------------------------------------------------------------------------

[[ "${MIDGARD_MAIN:-}" == "1" ]] || {
  echo "This script must be sourced from the midgard launcher." >&2
  return 1 2>/dev/null || exit 1
}

__restic_build_repo_url() {
  local region="$1" bucket="$2" prefix="$3"
  local host="s3.amazonaws.com"
  if [[ -n "$region" && "$region" != "us-east-1" ]]; then
    host="s3.${region}.amazonaws.com"
  fi
  printf 's3:%s/%s/%s' "$host" "$bucket" "$prefix"
}

# Run restic with a clean per-site environment to prevent cross-site leakage
__restic_run() {
  # args: <log_file> <aws_key> <aws_secret> <aws_region> <repo> <pw_file_or_empty> <cmd...>
  local log_file="$1"; shift
  local aws_key="$1"; shift
  local aws_secret="$1"; shift
  local aws_region="$1"; shift
  local repo="$1"; shift
  local pw_file="$1"; shift

  # Use per-command env; do NOT export globally (prevents bleed across sites).
  if [[ -n "$pw_file" ]]; then
    AWS_ACCESS_KEY_ID="$aws_key" \
    AWS_SECRET_ACCESS_KEY="$aws_secret" \
    AWS_DEFAULT_REGION="$aws_region" \
    AWS_REGION="$aws_region" \
    RESTIC_REPOSITORY="$repo" \
    RESTIC_PASSWORD_FILE="$pw_file" \
      "$@" >> "$log_file" 2>&1
  else
    # If you ever decide to use RESTIC_PASSWORD env instead of a file, wire it here.
    # For now we require a password file (or RESTIC_PASSWORD already set by caller).
    AWS_ACCESS_KEY_ID="$aws_key" \
    AWS_SECRET_ACCESS_KEY="$aws_secret" \
    AWS_DEFAULT_REGION="$aws_region" \
    AWS_REGION="$aws_region" \
    RESTIC_REPOSITORY="$repo" \
      "$@" >> "$log_file" 2>&1
  fi
}

__restic_run_stdout() {
  # args: <aws_key> <aws_secret> <aws_region> <repo> <pw_file_or_empty> <cmd...>
  local aws_key="$1"; shift
  local aws_secret="$1"; shift
  local aws_region="$1"; shift
  local repo="$1"; shift
  local pw_file="$1"; shift

  if [[ -n "$pw_file" ]]; then
    AWS_ACCESS_KEY_ID="$aws_key" \
    AWS_SECRET_ACCESS_KEY="$aws_secret" \
    AWS_DEFAULT_REGION="$aws_region" \
    AWS_REGION="$aws_region" \
    RESTIC_REPOSITORY="$repo" \
    RESTIC_PASSWORD_FILE="$pw_file" \
      "$@"
  else
    AWS_ACCESS_KEY_ID="$aws_key" \
    AWS_SECRET_ACCESS_KEY="$aws_secret" \
    AWS_DEFAULT_REGION="$aws_region" \
    AWS_REGION="$aws_region" \
    RESTIC_REPOSITORY="$repo" \
      "$@"
  fi
}

restic_list_snapshots_main() {
  local site="$1"
  local assoc_name="${CONFIG_SITES[$site]:-}"
  if [[ -z "$assoc_name" ]]; then
    echo "restic_list_snapshots_main: site not loaded: $site" >&2
    return 1
  fi

  local AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_S3_BUCKET AWS_DEFAULT_REGION AWS_S3_PATH
  AWS_ACCESS_KEY_ID="$(midgard_get_value_from_array "$assoc_name" AWS_ACCESS_KEY_ID)"
  AWS_SECRET_ACCESS_KEY="$(midgard_get_value_from_array "$assoc_name" AWS_SECRET_ACCESS_KEY)"
  AWS_S3_BUCKET="$(midgard_get_value_from_array "$assoc_name" AWS_S3_BUCKET)"
  AWS_DEFAULT_REGION="$(midgard_get_value_from_array "$assoc_name" AWS_DEFAULT_REGION)"
  AWS_S3_PATH="$(midgard_get_value_from_array "$assoc_name" AWS_S3_PATH)"

  local errors=()
  [[ -x "${RESTIC_BIN:-}" ]] || errors+=("RESTIC_BIN")
  [[ -n "$AWS_ACCESS_KEY_ID" ]] || errors+=("AWS_ACCESS_KEY_ID")
  [[ -n "$AWS_SECRET_ACCESS_KEY" ]] || errors+=("AWS_SECRET_ACCESS_KEY")
  [[ -n "$AWS_S3_BUCKET" ]] || errors+=("AWS_S3_BUCKET")
  [[ -n "$AWS_S3_PATH" ]] || errors+=("AWS_S3_PATH")
  [[ -n "$AWS_DEFAULT_REGION" ]] || errors+=("AWS_DEFAULT_REGION")
  if (( ${#errors[@]} )); then
    printf 'Please verify: %s\n' "${errors[*]}" >&2
    return 1
  fi

  local repo
  repo="$(__restic_build_repo_url "$AWS_DEFAULT_REGION" "$AWS_S3_BUCKET" "$AWS_S3_PATH")"
  if [[ -z "$repo" ]]; then
    echo "restic_list_snapshots_main: unable to construct repository URL" >&2
    return 1
  fi

  local script_dir root_dir data_dir restic_password_file pw_file
  script_dir="$(cd -- "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null; pwd -P)"
  root_dir="$(cd -- "${script_dir}/.." &>/dev/null; pwd -P)"
  data_dir="${SITES_DATA_DIR:-${root_dir}/sites-data}"
  restic_password_file="${RESTIC_PASSWORD_FILE:-${data_dir}/${site}/restic.pass}"
  pw_file=""
  if [[ -z "${RESTIC_PASSWORD:-}" ]]; then
    if [[ ! -r "$restic_password_file" ]]; then
      echo "restic_list_snapshots_main: missing readable ${data_dir}/${site}/restic.pass" >&2
      return 1
    fi
    pw_file="$restic_password_file"
  fi

  echo
  echo "Remote restic snapshots for ${site}"
  echo "Repository: ${repo}"
  echo

  __restic_run_stdout \
    "$AWS_ACCESS_KEY_ID" \
    "$AWS_SECRET_ACCESS_KEY" \
    "$AWS_DEFAULT_REGION" \
    "$repo" \
    "$pw_file" \
    "${RESTIC_BIN}" snapshots
}

restic_restore_snapshot_main() {
  local site="$1"
  local assoc_name="${CONFIG_SITES[$site]:-}"
  if [[ -z "$assoc_name" ]]; then
    echo "restic_restore_snapshot_main: site not loaded: $site" >&2
    return 1
  fi

  local AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_S3_BUCKET AWS_DEFAULT_REGION AWS_S3_PATH
  AWS_ACCESS_KEY_ID="$(midgard_get_value_from_array "$assoc_name" AWS_ACCESS_KEY_ID)"
  AWS_SECRET_ACCESS_KEY="$(midgard_get_value_from_array "$assoc_name" AWS_SECRET_ACCESS_KEY)"
  AWS_S3_BUCKET="$(midgard_get_value_from_array "$assoc_name" AWS_S3_BUCKET)"
  AWS_DEFAULT_REGION="$(midgard_get_value_from_array "$assoc_name" AWS_DEFAULT_REGION)"
  AWS_S3_PATH="$(midgard_get_value_from_array "$assoc_name" AWS_S3_PATH)"

  local errors=()
  [[ -x "${RESTIC_BIN:-}" ]] || errors+=("RESTIC_BIN")
  [[ -n "$AWS_ACCESS_KEY_ID" ]] || errors+=("AWS_ACCESS_KEY_ID")
  [[ -n "$AWS_SECRET_ACCESS_KEY" ]] || errors+=("AWS_SECRET_ACCESS_KEY")
  [[ -n "$AWS_S3_BUCKET" ]] || errors+=("AWS_S3_BUCKET")
  [[ -n "$AWS_S3_PATH" ]] || errors+=("AWS_S3_PATH")
  [[ -n "$AWS_DEFAULT_REGION" ]] || errors+=("AWS_DEFAULT_REGION")
  if (( ${#errors[@]} )); then
    printf 'Please verify: %s\n' "${errors[*]}" >&2
    return 1
  fi

  local repo
  repo="$(__restic_build_repo_url "$AWS_DEFAULT_REGION" "$AWS_S3_BUCKET" "$AWS_S3_PATH")"
  if [[ -z "$repo" ]]; then
    echo "restic_restore_snapshot_main: unable to construct repository URL" >&2
    return 1
  fi

  local script_dir root_dir data_dir restic_password_file pw_file
  script_dir="$(cd -- "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null; pwd -P)"
  root_dir="$(cd -- "${script_dir}/.." &>/dev/null; pwd -P)"
  data_dir="${SITES_DATA_DIR:-${root_dir}/sites-data}"
  restic_password_file="${RESTIC_PASSWORD_FILE:-${data_dir}/${site}/restic.pass}"
  pw_file=""
  if [[ -z "${RESTIC_PASSWORD:-}" ]]; then
    if [[ ! -r "$restic_password_file" ]]; then
      echo "restic_restore_snapshot_main: missing readable ${data_dir}/${site}/restic.pass" >&2
      return 1
    fi
    pw_file="$restic_password_file"
  fi

  local snapshot_id=""
  printf "ID: "
  read -r snapshot_id || return 1
  if [[ -z "$snapshot_id" ]]; then
    echo "Snapshot ID is required"
    return 1
  fi

  local default_target="${HOME}/RESTIC_RESTORE/${site}/${snapshot_id}"
  local restore_target=""
  printf "Restore to [%s]: " "$default_target"
  read -r restore_target || return 1
  if [[ -z "$restore_target" ]]; then
    restore_target="$default_target"
  fi

  mkdir -p "$restore_target"

  echo
  echo "Restoring snapshot ${snapshot_id} for ${site}"
  echo "Target: ${restore_target}"
  echo

  __restic_run_stdout \
    "$AWS_ACCESS_KEY_ID" \
    "$AWS_SECRET_ACCESS_KEY" \
    "$AWS_DEFAULT_REGION" \
    "$repo" \
    "$pw_file" \
    "${RESTIC_BIN}" restore "$snapshot_id" --target "$restore_target"
}

restic_menu_main() {
  local site="$1"
  local choice=""

  while true; do
    echo
    echo "Restic menu for ${site}"
    echo "[1] list remote backup"
    echo "[2] Restore backup"
    echo "[q] Quit"
    printf "> "
    read -r choice || return 0

    case "$choice" in
      1)
        restic_list_snapshots_main "$site"
        ;;
      2)
        restic_restore_snapshot_main "$site"
        ;;
      q|Q)
        return 0
        ;;
      *)
        echo "Invalid choice"
        ;;
    esac
  done
}

restic_sync_main() {
  local site="$1"

  mkdir -p "${MIDGARD_SESSION_LOG_DIR}" "${MIDGARD_SESSION_REPORT_DIR}"

  local SITE_LOG_FILE SITE_REPORT_FILE
  SITE_LOG_FILE="${MIDGARD_SESSION_LOG_DIR}/${site}.log"
  SITE_REPORT_FILE="${MIDGARD_SESSION_REPORT_DIR}/${site}.report"

  echo -e "$(midgard_current_time) ${site} Restic Backup Sync ${c_light_blue}[${c_green}STARTED${c_light_blue}]${c_reset}"
  echo "$(midgard_current_time) Restic Backup Sync [STARTED]" >> "$SITE_LOG_FILE"

  if [[ -z "$site" ]]; then
    echo "restic_sync_main: missing site" >&2
    echo "$(midgard_current_time) Restic Backup Sync [FAILED]" >> "$SITE_LOG_FILE"
    echo "RESTIC=FAIL" >> "$SITE_REPORT_FILE"
    return 1
  fi

  local assoc_name="${CONFIG_SITES[$site]:-}"
  if [[ -z "$assoc_name" ]]; then
    echo "restic_sync_main: site not loaded: $site" >&2
    echo "$(midgard_current_time) Restic Backup Sync [FAILED]" >> "$SITE_LOG_FILE"
    echo "RESTIC=FAIL" >> "$SITE_REPORT_FILE"
    return 1
  fi

  # fetch fields (local to function; avoids accidental reuse)
  local LOCAL_SYNC_PATH RESTIC_RETENTION_DAYS
  local AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_S3_BUCKET AWS_DEFAULT_REGION AWS_S3_PATH

  LOCAL_SYNC_PATH="$(midgard_get_value_from_array "$assoc_name" LOCAL_SYNC_PATH)"
  RESTIC_RETENTION_DAYS="$(midgard_get_value_from_array "$assoc_name" RESTIC_RETENTION_DAYS)"
  AWS_ACCESS_KEY_ID="$(midgard_get_value_from_array "$assoc_name" AWS_ACCESS_KEY_ID)"
  AWS_SECRET_ACCESS_KEY="$(midgard_get_value_from_array "$assoc_name" AWS_SECRET_ACCESS_KEY)"
  AWS_S3_BUCKET="$(midgard_get_value_from_array "$assoc_name" AWS_S3_BUCKET)"
  AWS_DEFAULT_REGION="$(midgard_get_value_from_array "$assoc_name" AWS_DEFAULT_REGION)"
  AWS_S3_PATH="$(midgard_get_value_from_array "$assoc_name" AWS_S3_PATH)"

  # sanity
  local errors=()
  [[ -x "${RESTIC_BIN:-}" ]] || errors+=("RESTIC_BIN")
  [[ -n "$LOCAL_SYNC_PATH" ]] || errors+=("LOCAL_SYNC_PATH")
  [[ -n "$AWS_ACCESS_KEY_ID" ]] || errors+=("AWS_ACCESS_KEY_ID")
  [[ -n "$AWS_SECRET_ACCESS_KEY" ]] || errors+=("AWS_SECRET_ACCESS_KEY")
  [[ -n "$AWS_S3_BUCKET" ]] || errors+=("AWS_S3_BUCKET")
  [[ -n "$AWS_S3_PATH" ]] || errors+=("AWS_S3_PATH")
  [[ -n "$AWS_DEFAULT_REGION" ]] || errors+=("AWS_DEFAULT_REGION")

  if (( ${#errors[@]} )); then
    for err in "${errors[@]}"; do
      echo -e "$(midgard_current_time) ${site}   Please verify ${c_light_red}${err}${c_reset}"
      echo "$(midgard_current_time) ${site}   Please verify ${err}" >> "$SITE_LOG_FILE"
    done
    echo -e "$(midgard_current_time) ${site} Restic Backup Sync ${c_light_blue}[${c_light_red}FAILED${c_light_blue}]${c_reset}"
    echo "$(midgard_current_time) Restic Backup Sync [FAILED]" >> "$SITE_LOG_FILE"
    echo "RESTIC=FAIL" >> "$SITE_REPORT_FILE"
    return 1
  fi

  # path checks
  if [[ ! -d "$LOCAL_SYNC_PATH" ]]; then
    echo -e "$(midgard_current_time) ${site}   LOCAL_SYNC_PATH missing -> mark SKIPPED: ${c_yellow}${LOCAL_SYNC_PATH}${c_reset}"
    echo "$(midgard_current_time) ${site}   LOCAL_SYNC_PATH missing -> mark SKIPPED: ${LOCAL_SYNC_PATH}" >> "$SITE_LOG_FILE"
    echo -e "$(midgard_current_time) ${site} Restic Backup Sync ${c_light_blue}[${c_yellow}SKIPPED${c_light_blue}]${c_reset}"
    echo "$(midgard_current_time) Restic Backup Sync [SKIPPED]" >> "$SITE_LOG_FILE"
    echo "RESTIC=SKIPPED" >> "$SITE_REPORT_FILE"
    return 0
  fi

  # retention days
  local keep_days="${RESTIC_RETENTION_DAYS:-30}"
  if ! [[ "$keep_days" =~ ^[0-9]+$ ]]; then
    echo "$(midgard_current_time) ${site}   RESTIC_RETENTION_DAYS not numeric ('$keep_days'); defaulting to 30" >> "$SITE_LOG_FILE"
    keep_days="30"
  fi

  # repo url
  local repo
  repo="$(__restic_build_repo_url "$AWS_DEFAULT_REGION" "$AWS_S3_BUCKET" "$AWS_S3_PATH")"
  if [[ -z "$repo" ]]; then
    echo "$(midgard_current_time) ${site}   Unable to construct repository URL" >> "$SITE_LOG_FILE"
    echo -e "$(midgard_current_time) ${site} Restic Backup Sync ${c_light_blue}[${c_light_red}FAILED${c_light_blue}]${c_reset}"
    echo "$(midgard_current_time) Restic Backup Sync [FAILED]" >> "$SITE_LOG_FILE"
    echo "RESTIC=FAIL" >> "$SITE_REPORT_FILE"
    return 1
  fi

  # password file logic
  local script_dir root_dir data_dir restic_password_file
  script_dir="$(cd -- "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null; pwd -P)"
  root_dir="$(cd -- "${script_dir}/.." &>/dev/null; pwd -P)"
  data_dir="${SITES_DATA_DIR:-${root_dir}/sites-data}"
  restic_password_file="${RESTIC_PASSWORD_FILE:-${data_dir}/${site}/restic.pass}"

  if [[ -z "${RESTIC_PASSWORD:-}" && ( -z "${restic_password_file:-}" || ! -r "$restic_password_file" ) ]]; then
    echo "$(midgard_current_time) ${site}   Missing RESTIC_PASSWORD or readable ${data_dir}/${site}/restic.pass" >> "$SITE_LOG_FILE"
    echo -e "$(midgard_current_time) ${site} Restic Backup Sync ${c_light_blue}[${c_light_red}FAILED${c_light_blue}]${c_reset}"
    echo "$(midgard_current_time) Restic Backup Sync [FAILED]" >> "$SITE_LOG_FILE"
    echo "RESTIC=FAIL" >> "$SITE_REPORT_FILE"
    return 1
  fi

  echo "$(midgard_current_time) ${site}   Repository: $repo" >> "$SITE_LOG_FILE"
  echo "$(midgard_current_time) ${site}   Backing up: $LOCAL_SYNC_PATH" >> "$SITE_LOG_FILE"
  echo "$(midgard_current_time) ${site}   Retention: keep-within ${keep_days}d" >> "$SITE_LOG_FILE"

  local tries="${DEFAULT_RETRIES:-3}"
  local backoff="${DEFAULT_RETRY_BACKOFF_SECS:-5}"
  local n rc=0

  # Decide password method for __restic_run:
  # If RESTIC_PASSWORD is set by caller, we rely on it (no pw file passed).
  # Otherwise pass the password file explicitly.
  local pw_file=""
  if [[ -z "${RESTIC_PASSWORD:-}" ]]; then
    pw_file="$restic_password_file"
  fi

  # probe snapshots
  rc=0
  for ((n=1; n<=tries; n++)); do
    __restic_run "$SITE_LOG_FILE" "$AWS_ACCESS_KEY_ID" "$AWS_SECRET_ACCESS_KEY" "$AWS_DEFAULT_REGION" "$repo" "$pw_file" \
      "${RESTIC_BIN}" snapshots && { rc=0; break; } || rc=$?
    (( n < tries )) && { echo "retry snapshots $n/${tries} in ${backoff}s (rc=$rc)" >> "$SITE_LOG_FILE"; sleep "$backoff"; }
  done

  # init if needed
  if (( rc != 0 )); then
    echo "$(midgard_current_time) ${site}   Repository not initialized; running restic init" >> "$SITE_LOG_FILE"
    rc=0
    for ((n=1; n<=tries; n++)); do
      __restic_run "$SITE_LOG_FILE" "$AWS_ACCESS_KEY_ID" "$AWS_SECRET_ACCESS_KEY" "$AWS_DEFAULT_REGION" "$repo" "$pw_file" \
        "${RESTIC_BIN}" init && { rc=0; break; } || rc=$?
      (( n < tries )) && { echo "retry init $n/${tries} in ${backoff}s (rc=$rc)" >> "$SITE_LOG_FILE"; sleep "$backoff"; }
    done
    if (( rc != 0 )); then
      echo -e "$(midgard_current_time) ${site} Restic Backup Sync ${c_light_blue}[${c_light_red}FAILED${c_light_blue}]${c_reset}"
      echo "$(midgard_current_time) Restic Backup Sync [FAILED]" >> "$SITE_LOG_FILE"
      echo "RESTIC=FAIL" >> "$SITE_REPORT_FILE"
      return 1
    fi
  fi

  # backup
  rc=0
  for ((n=1; n<=tries; n++)); do
    __restic_run "$SITE_LOG_FILE" "$AWS_ACCESS_KEY_ID" "$AWS_SECRET_ACCESS_KEY" "$AWS_DEFAULT_REGION" "$repo" "$pw_file" \
      "${RESTIC_BIN}" backup \
        --one-file-system \
        --host "${RUN_AS_HOST}" \
        --tag "midgard" --tag "$site" \
        "$LOCAL_SYNC_PATH" && { rc=0; break; } || rc=$?
    (( n < tries )) && { echo "retry backup $n/${tries} in ${backoff}s (rc=$rc)" >> "$SITE_LOG_FILE"; sleep "$backoff"; }
  done
  if (( rc != 0 )); then
    echo -e "$(midgard_current_time) ${site} Restic Backup Sync ${c_light_blue}[${c_light_red}FAILED${c_light_blue}]${c_reset}"
    echo "$(midgard_current_time) Restic Backup Sync [FAILED]" >> "$SITE_LOG_FILE"
    echo "RESTIC=FAIL" >> "$SITE_REPORT_FILE"
    return 1
  fi

  # retention prune
  rc=0
  for ((n=1; n<=tries; n++)); do
    __restic_run "$SITE_LOG_FILE" "$AWS_ACCESS_KEY_ID" "$AWS_SECRET_ACCESS_KEY" "$AWS_DEFAULT_REGION" "$repo" "$pw_file" \
      "${RESTIC_BIN}" forget --keep-within "${keep_days}d" --prune && { rc=0; break; } || rc=$?
    (( n < tries )) && { echo "retry prune $n/${tries} in ${backoff}s (rc=$rc)" >> "$SITE_LOG_FILE"; sleep "$backoff"; }
  done
  if (( rc != 0 )); then
    echo -e "$(midgard_current_time) ${site} Restic Backup Sync ${c_light_blue}[${c_light_red}FAILED${c_light_blue}]${c_reset}"
    echo "$(midgard_current_time) Restic Backup Sync [FAILED]" >> "$SITE_LOG_FILE"
    echo "RESTIC=FAIL" >> "$SITE_REPORT_FILE"
    return 1
  fi

  echo -e "$(midgard_current_time) ${site} Restic Backup Sync ${c_light_blue}[${c_green}SUCCESS${c_light_blue}]${c_reset}"
  echo "$(midgard_current_time) Restic Backup Sync [SUCCESS]" >> "$SITE_LOG_FILE"
  echo "RESTIC=OK" >> "$SITE_REPORT_FILE"
  return 0
}
